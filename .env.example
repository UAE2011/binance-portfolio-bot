# ============================================================
# Binance Portfolio Bot — Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Binance API ---
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
USE_TESTNET=true

# --- Telegram Notifications ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- AI Trading (Groq FREE — https://console.groq.com) ---
# FAST model: llama-3.1-8b-instant — ultra-fast, ~0.1s latency, FREE
# STRONG model: llama-3.3-70b-versatile — excellent reasoning, ~0.3s latency, FREE
# Get free API key at: https://console.groq.com (no credit card needed)
GROQ_API_KEY=your_groq_api_key_here
AI_BASE_URL=https://api.groq.com/openai/v1
AI_TRADING_ENABLED=true
AI_FAST_MODEL=llama-3.1-8b-instant
AI_STRONG_MODEL=llama-3.3-70b-versatile
AI_MODEL=llama-3.3-70b-versatile
AI_MIN_CONFIDENCE=0.65
AI_ANALYSIS_TIMEOUT=30
AI_MAX_DAILY_CALLS=500
AI_VETO_POWER=true
AI_DAILY_COST_LIMIT=0.00

# --- Risk Management (SOL Bot Defaults) ---
RISK_LEVEL=3
MAX_POSITION_SIZE=0.10
MAX_RISK_PER_TRADE=0.02
MAX_OPEN_POSITIONS=10
MIN_CASH_RESERVE=0.20
MAX_PORTFOLIO_DRAWDOWN=0.20
MAX_DAILY_LOSS=0.03
STOP_LOSS_PCT=0.03
TAKE_PROFIT_PCT=0.06
TRAILING_STOP_ACTIVATION_PCT=0.03
TRAILING_STOP_DISTANCE_PCT=0.015
PARTIAL_TP_ENABLED=true
PARTIAL_TP_PCT=0.50
PARTIAL_TP_TRIGGER=0.06
RUNNER_TRAILING_DISTANCE=0.02
SUPPORT_BREAK_EXIT=true
SUPPORT_BREAK_THRESHOLD=0.005

# --- Strategy ---
CONFLUENCE_SCORE_THRESHOLD=70
SCAN_INTERVAL_SECONDS=60
SCAN_INTERVAL_HOURS=4
TIMEFRAMES=15m,1h,4h
PRIMARY_TIMEFRAME=1h
ENTRY_TIMEFRAME=15m
TREND_TIMEFRAME=4h
ATR_PERIOD=14
ATR_STOP_MULTIPLIER=2.5
RSI_PERIOD=14
VOLUME_SPIKE_MULTIPLIER=2.0
VOLUME_SPIKE_LOOKBACK=20
SR_LOOKBACK_CANDLES=100
SR_PROXIMITY_PCT=0.01
REBALANCE_DAY=6
HMM_RETRAIN_DAY=6
HMM_LOOKBACK_DAYS=90
NEWS_CHECK_INTERVAL_MINUTES=15
MIN_24H_VOLUME=1000000
MAX_WATCHLIST_SIZE=50

# --- Calibration ---
CALIBRATION_ENABLED=true
CALIBRATION_MIN_TRADES=50
CALIBRATION_LOOKBACK_TRADES=50
CALIBRATION_INTERVAL_TRADES=50
WALK_FORWARD_ENABLED=true

# --- Operational ---
LOG_LEVEL=INFO
DB_PATH=data/bot.db
TIMEZONE=UTC
WATCHDOG_INTERVAL_SECONDS=10
HEARTBEAT_FILE=/tmp/bot_heartbeat
STATE_FILE=data/bot_state.json
WEEKLY_REPORT_DAY=0
WEEKLY_REPORT_HOUR=9
