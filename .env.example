# =============================================================================
# Binance Portfolio Bot — Environment Variables
# =============================================================================

# ── Binance ──────────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
USE_TESTNET=false                         # true = testnet (safe testing), false = LIVE

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── AI (Google Gemini — FREE, 1M+ tokens/day) ────────────────────────────────
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
AI_FAST_MODEL=gemini-2.0-flash
AI_STRONG_MODEL=gemini-2.5-flash-preview-04-17
AI_TRADING_ENABLED=true
AI_VETO_POWER=true
AI_MIN_CONFIDENCE=0.60
AI_VETO_MIN_CONFIDENCE=0.60
AI_MAX_CALLS_PER_CYCLE=5
AI_MAX_DAILY_CALLS=500

# ── Risk Management (Playbook: Quarter Kelly + Anti-Martingale) ───────────────
KELLY_FRACTION=0.25                       # quarter Kelly (25% of full Kelly)
MAX_RISK_PER_TRADE=0.02                   # 2% of portfolio per trade
MAX_POSITION_SIZE=0.15                    # max 15% per position
MAX_OPEN_POSITIONS=8
MAX_PORTFOLIO_HEAT=0.10                   # max 10% total at risk (all positions)
MIN_CASH_RESERVE=0.15                     # always keep 15% as cash minimum

# Stop-loss / Take-profit
STOP_LOSS_PCT=0.03                        # 3% hard stop
TAKE_PROFIT_PCT=0.06                      # 6% TP1 (50% of position)
ATR_STOP_MULTIPLIER=3.0                   # 3× ATR trailing stop (crypto-tuned)
ATR_TP_MULTIPLIER=4.5                     # 4.5× ATR for TP2 target
CHANDELIER_ATR_PERIOD=22
CHANDELIER_ATR_MULT=3.0

# Partial TP (50/50 split — lock 50% at 6%, trail remainder)
PARTIAL_TP_ENABLED=true
PARTIAL_TP_PCT=0.50                       # sell 50% at TP1
PARTIAL_TP_TRIGGER=0.06                   # trigger at 6% gain (2R)
RUNNER_TRAILING_DISTANCE=0.02             # 2% trail on runner

# Circuit breakers (escalating drawdown response)
CIRCUIT_BREAKER_1=0.05                    # 5% → reduce size 50%
CIRCUIT_BREAKER_2=0.10                    # 10% → close 50% of positions
CIRCUIT_BREAKER_3=0.15                    # 15% → capital preservation mode
MAX_PORTFOLIO_DRAWDOWN=0.20               # 20% → kill switch
MAX_DAILY_LOSS=0.03                       # 3% max daily loss

# Anti-martingale scaling
WIN_SCALE_UP=1.10                         # +10% size after each win
LOSS_SCALE_DOWN=0.90                      # -10% size after each loss
MAX_SCALE_FACTOR=2.0
MIN_SCALE_FACTOR=0.25

# ── Strategy (Playbook-optimized) ────────────────────────────────────────────
CONFLUENCE_SCORE_THRESHOLD=45            # min score to enter (0-100)
PRIMARY_TIMEFRAME=1h
ENTRY_TIMEFRAME=15m
TREND_TIMEFRAME=4h
SCAN_INTERVAL_SECONDS=60

# Indicators (crypto-optimized from research)
RSI_PERIOD=14
RSI_FAST_PERIOD=7
RSI_MOMENTUM_THRESHOLD=50.0              # momentum mode: >50 = bullish
MACD_FAST=8                              # intraday-optimized (vs standard 12)
MACD_SLOW=17                             # (vs standard 26)
MACD_SIGNAL_PERIOD=9
ATR_PERIOD=14
SUPERTREND_ATR_PERIOD=14
SUPERTREND_MULTIPLIER=3.5               # 3.5× ATR (crypto-tuned)

# Volume (breakouts need 1.5-2× SMA confirmation)
VOLUME_SPIKE_MULTIPLIER=1.5
VOLUME_BREAKOUT_MULTIPLIER=2.0
VOLUME_SPIKE_LOOKBACK=20

# Support & Resistance
SR_LOOKBACK_CANDLES=100
SR_PROXIMITY_PCT=0.015

# Time-of-day bonus (London/NY overlap = peak liquidity)
PEAK_HOURS_START=14                      # 14:00 UTC
PEAK_HOURS_END=22                        # 22:00 UTC
PEAK_HOURS_BONUS=5                       # +5 pts confluence

# Asset universe
MIN_24H_VOLUME=5000000                   # $5M minimum (institutional liquidity)
MAX_WATCHLIST_SIZE=50

# ── Portfolio Construction (Core-Satellite) ───────────────────────────────────
CORE_ALLOCATION=0.50                     # 50% BTC/ETH core
SATELLITE_ALLOCATION=0.35               # 35% quality alts
SPECULATIVE_ALLOCATION=0.05             # 5% high-risk/high-reward
DRY_POWDER=0.10                         # 10% cash reserve

# Sector rotation thresholds
BTC_DOM_ALTSEASON_THRESHOLD=0.50        # BTC dom < 50% = altcoin season
BTC_DOM_BTC_FOCUS_THRESHOLD=0.65        # BTC dom > 65% = BTC focus
ALTSEASON_INDEX_ENTRY=50                # enter alts when index > 50
ALTSEASON_INDEX_EXIT=75                 # late cycle signal > 75

# Rebalancing
REBALANCE_DRIFT_THRESHOLD=0.12          # rebalance when 12% off target
MAX_SINGLE_POSITION_PCT=0.15            # 15% max per position

# Smart DCA during extreme fear (F&G < 15)
DCA_FEAR_THRESHOLD=15
DCA_BUDGET_PCT=0.05                     # 5% of portfolio per DCA cycle
DCA_TRANCHES=5
DCA_MULTIPLIER=3.0                      # 3× normal DCA during extreme fear

# ── Regime Configuration ─────────────────────────────────────────────────────
BEAR_CASH_RESERVE=0.70                  # 70% stablecoin in bear
SIDEWAYS_CASH_RESERVE=0.40             # 40% in sideways
BULL_CASH_RESERVE=0.15                 # 15% in bull (aggressive deployment)
ENABLE_ALTCOIN_ROTATION=true

# ── Calibration ──────────────────────────────────────────────────────────────
CALIBRATION_ENABLED=true
CALIBRATION_MIN_TRADES=20
CALIBRATION_LOOKBACK_TRADES=50
CALIBRATION_INTERVAL_TRADES=20
WALK_FORWARD_ENABLED=true

# ── Operations ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DB_PATH=data/bot.db
TIMEZONE=UTC
WATCHDOG_INTERVAL_SECONDS=10
NEWS_CHECK_INTERVAL_MINUTES=15
WEEKLY_REPORT_DAY=0
WEEKLY_REPORT_HOUR=9
